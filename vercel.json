{
  "rewrites": [
    {
      "source": "/api/tram-positions",
      "destination": "/api/tram-positions"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://opsview.vercel.app" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
